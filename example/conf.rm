#   <- Comment token, no multiline token, just use line by line commentary.
//  <- Also a comment token
;   <- also also

myvar=progtest.exe
rebuild=true
args=test -debug

build 
{
    compiler=g++
    flags=-std=c++17 -Wall -Werror -Wextra -ggdb
    src=src/*.cpp
    include=src/include
    target=${myvar}
}

run
{
    target=${myvar}
    rebuild=${rebuild}
    args=${args}
}
